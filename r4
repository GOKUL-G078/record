
#include <stdio.h>

#define MAX 50


void findSaddlePoints(int mat[MAX][MAX], int r, int c);
void findSecondLargest(int mat[MAX][MAX], int r, int c);

int main() {
    int mat[MAX][MAX], r, c, i, j;

    printf("Enter number of rows and columns: ");
    scanf("%d %d", &r, &c);

    printf("Enter elements of the matrix:\n");
    for (i = 0; i < r; i++) {
        for (j = 0; j < c; j++) {
            scanf("%d", &mat[i][j]);
        }
    }

    findSaddlePoints(mat, r, c);
    findSecondLargest(mat, r, c);

    return 0;
}

void findSaddlePoints(int mat[MAX][MAX], int r, int c) {
    int i, j, k, min_row, col_ind, isSaddle, found = 0;

    printf("\nChecking for Saddle Points...\n");
    for (i = 0; i < r; i++) {
        min_row = mat[i][0];
        col_ind = 0;
        for (j = 1; j < c; j++) {
            if (mat[i][j] < min_row) {
                min_row = mat[i][j];
                col_ind = j;
            }
        }

        isSaddle = 1;
        for (k = 0; k < r; k++) {
            if (mat[k][col_ind] > min_row) {
                isSaddle = 0;
                break;
            }
        }

        if (isSaddle) 
        {
            printf("Saddle Point found: %d at [%d][%d]\n", min_row, i, col_ind);
            found = 1;
        }
    }

    if (!found)
    {
        printf("No saddle points found in this matrix.\n");
    }
}

void findSecondLargest(int mat[MAX][MAX], int r, int c) 
{
    int temp, i, j, k = 0;
    int size = r * c;
    int arr[MAX * MAX];

    for (i = 0; i < r; i++)
    {
        for (j = 0; j < c; j++) 
        {
            arr[k++] = mat[i][j];
        }
    }
    for (i = 0; i < size - 1; i++) 
    {
        for (j = 0; j < size - i - 1; j++) 
        {
            if (arr[j] < arr[j + 1]) 
            {
                temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }
    int largest = arr[0];
    int secondLargest = -99999; 
    int found = 0;

    for (i = 1; i < size; i++) 
    {
        if (arr[i] < largest) 
        {
            secondLargest = arr[i];
            found = 1;
            break;
        }
    }

    if (found)
    {
        printf("\nSecond Largest Element: %d\n", secondLargest);
    }
    else 
    {
        printf("\nNo second largest element exists (all elements are equal).\n");
    }
}
