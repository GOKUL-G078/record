// a) largest number using nested if-
float largest(float m1, float m2, float m3)
{
    if (m1 >= m2) 
    {
        if (m1 >= m3)
            return m1;
        else
            return m3;
    } 
    else
    {
        if (m2 >= m3)
            return m2;
        else
            return m3;
    }
}
// b) Find the smallest using if–else if
float smallest(float m1, float m2, float m3)
{
    if (m1 <= m2 && m1 <= m3)
    {
        return m1;
    }
    else if (m2 <= m1 && m2 <= m3)
    {
        return m2;
    } 
    else
    {
        return m3;
    }
}

